# ──────────────────────────────────────────────
# WRITE CSVs
# ──────────────────────────────────────────────

def write_csv(filename, rows):
    path = os.path.join(OUTPUT_DIR, filename)
    with open(path, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerows(rows)
    print(f"  Written: {path}  ({len(rows) - 1} data rows)")


