    write_csv("nycf_cancer_types.csv",      CANCER_TYPES)
    write_csv("nycf_hospital_referrals.csv",HOSPITAL_REFERRALS)
    write_csv("nycf_patient_geography.csv", PATIENT_GEOGRAPHY)
    write_csv("nycf_grants_quarterly.csv",  GRANTS_QUARTERLY)
    print("\nDone! All 6 CSV files written to the ./output/ folder.")
